package linkedlist;

public class Remove_Cycle extends Singly_LL {

	public Remove_Cycle(Node head) {
		super(head);
	}

	public void removeCycle() {
		Node slow = head;
		Node fast = head;

		while (fast != null && fast.getNext() != null) {
			slow = slow.getNext();
			fast = fast.getNext().getNext();
			if (slow == fast) {
				System.out.println("Cycle Found !!!!");
				break;
			}
		}
		if(fast != null && fast.getNext() != null&&slow!=fast) {
			System.out.println("Cycle Not Present!!!!!");
			return;
		}
		int lengthCount = 0;

		do {
			lengthCount++;
			slow = slow.getNext();
		} while (slow != fast);

		fast = head;
		while (fast != slow) {
			fast = fast.getNext();
			slow = slow.getNext();
			lengthCount++;
		}
		slow = head;
		for (int i = 1; i < lengthCount - 1; i++) {
			slow = slow.getNext();
		}
		slow.setNext(null);
		System.out.println("Cycle Removed SucessFully!!!!");
	}

	public void formCycle(int data) {
		Node temp = head;
		Node pSave = null;
		while (temp.getNext() != null) {
			if (temp.getData() == data) {
				pSave = temp;
			}
			temp = temp.getNext();
		}
		temp.setNext(pSave);

	}

}
