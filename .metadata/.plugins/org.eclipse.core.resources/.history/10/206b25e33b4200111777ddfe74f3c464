	public int countNode() {
		if(head == null)
			return 0;
		Node temp =head;
		int count=0;
		while(temp!=null) {
			count++;
			temp= temp.getNext();
		}
		return count;
	}
	public void reversedLinkedList() {
		if(head == null) {
			System.out.println("linked List is Empty!!!!");
			return ;
		}
		Node prev = null ;
		Node curr = head;
		Node next = null;
		
		while(curr!=null) {
		   next = curr.getNext();
		   curr.setNext(prev);
		   prev= curr;
		   curr=next;
		}
		head=prev;
		System.out.println("Reversed linked List is Completed !!!!!");
		
	}
	public void displayAlternateNode() {
		if(head == null) {
			System.out.println("linked List is Empty!!!!");
			return ;
		}
		Node temp =head;
		while (/* temp.getNext()!=null|| */temp!=null ) {
			System.out.println(temp.getData()+" -> ");
			if(temp.getNext()!=null)
			temp =temp.getNext().getNext();
			else
				break;
		}
	}
	public void swapAlternative() {
		if(head == null||head.getNext()==null) {
			System.out.println("linked List is Empty!!!!");
			return ;
		}
		Node temp =head;
		while(temp.getNext()!=null||temp!=null ) {
			Node helper1 = temp.getNext();
			Node helper2 = temp.getNext().getNext();
			temp.setNext(helper2.getNext());
			helper1.setNext(temp);
			helper2.setNext(helper1);
			temp=temp.getNext().getNext();	
		}
	}

}
