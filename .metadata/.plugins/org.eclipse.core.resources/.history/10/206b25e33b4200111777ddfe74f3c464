	public void insertAfterData(int data,int key) {
		Node newNode=new Node(data);
		if(head == null) {
			System.out.println("Invalid Key!!!!!");
			return;
		}
		Node temp = head;
		while(temp!=null&& temp.getData() != key) {
			temp=temp.getNext();
		}
		if(temp.getNext()==null) {
			System.out.println("Invalid Key !!!!!!!!!!");
		}
		else {
			newNode.setNext(temp.getNext());
