	void patternStar1(int n,int total) {
		if (n == 0)
			return;

		
		System.out.println();
		printStar1(n);
		printSpace1(total-n);
		patternStar1(n - 1,total);

	}

	void printStar1(int n) {
		if (n == 0)
			return;
		printStar1(n - 1);
		System.out.print("* ");
		
	}

	void printSpace1(int n) {
