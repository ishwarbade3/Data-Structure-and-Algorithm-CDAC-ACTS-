public class RecurssionDemo {
	public void fun(int n) {
		if (n > 5)
			return;
		System.out.print("  " + n);
		fun(n + 1);
		// return; // no requirement
	}

	void fun1(int n) {
		if (n > 5)
			return;
		fun1(n + 1);
		System.out.print("  " + n);

	}

	public void displayArray(int a[], int i) {
		if (i > a.length - 1)
			return;
		System.out.print("  " + a[i]);
		displayArray(a, i + 1);
	}

	public int sumArray(int a[], int i) {
		if (i == a.length - 1)
			return a[i];

		return a[i] + sumArray(a, i + 1);
	}

	int countDigit(int n) {
		if (n / 10 == 0)
			return 1;
		return 1 + countDigit(n / 10);
	}

	int sumOfDigit(int n) {
		if (n / 10 == 0)
			return n;
		return n % 10 + sumOfDigit(n / 10);
	}

	void reverseNum(int n) {
		if (n / 10 == 0) {
			System.out.print(n);
			return;
		}
		System.out.print(n % 10);
		reverseNum(n / 10);
	}

	public int powerFun(int n, int x) {
		if (x == 0)
			return 1;
		return n * powerFun(n, x - 1);
	}

	void displayLinkedList(LinkedList<Integer> ll, int i) {
		if (i == ll.size())
			return;
		System.out.print(ll.get(i) + " ->");
		displayLinkedList(ll, i + 1);
	}

	void patternStar(int n, int total) {
		if (n == 0)
			return;

		patternStar(n - 1, total);
		printSpace(total - n);
		printStar(n);
		System.out.println();

	}

	void printStar(int n) {
		if (n == 0)
			return;
		System.out.print("* ");
		printStar(n - 1);
	}

	void printSpace(int n) {
		if (n == 0)
			return;

		printSpace(n - 1);
		System.out.print(" ");
	}

	int revNum(int n, int rev) {
		if (n > 0) {
			rev = (rev * 10) + n % 10;
			n /= 10;
			return revNum(n, rev);
		}

		return rev;
	}

	public int rserise(int n) {
		int sum;
		if (n == 0) {
			return 0;
		}
		sum = n + rserise(n - 1);
		System.out.print(n + " ");
		return sum;
	}

